# Base de données PostgreSQL
DATABASE_URL="postgresql://cvbuilder:cvbuilder_secret@localhost:5432/cvbuilder_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-32-chars-min"

# Claude API (Anthropic)
ANTHROPIC_API_KEY=""
# Modèle utilisé pour le parsing CV — claude-haiku-4-5-20251001 (défaut, rapide et économique)
AI_MODEL="claude-haiku-4-5-20251001"

# Cloudflare R2 (compatible S3)
R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cv-builder"
R2_PUBLIC_URL="https://pub-<hash>.r2.dev"
