generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  passwordHash    String
  logoUrl         String?
  primaryColor    String   @default("#3b5bdb")
  secondaryColor  String   @default("#ffffff")
  fontFamily      String   @default("Arial")
  sectionSettings Json?
  blockSettings   Json?
  cvs             Cv[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("companies")
}

model Cv {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  originalFileUrl  String
  originalFileName String
  status           CvStatus        @default(PENDING)
  rawText          String?
  parsedData       Json?
  templateId       Int?
  generatedFileUrl String?
  contact          Contact?
  experiences      Experience[]
  skills           Skill[]
  educations       Education[]
  languages        Language[]
  certifications   Certification[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("cvs")
}

enum CvStatus {
  PENDING
  TEXT_EXTRACTED
  PARSED
  GENERATED
}

model Contact {
  id                String  @id @default(cuid())
  cvId              String  @unique
  cv                Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  firstName         String  @default("")
  lastName          String  @default("")
  headline          String?
  seniority         String?
  yearsOfExperience String?
  address           String?
  email             String?
  phone             String?
  linkedin          String?
  github            String?
  photoUrl          String?
  profileText       String?

  @@map("contacts")
}

model Experience {
  id           String  @id @default(cuid())
  cvId         String
  cv           Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  title        String  @default("")
  company      String  @default("")
  client       String?
  startDate    String  @default("")
  endDate      String?
  isCurrent    Boolean @default(false)
  context      String?
  achievements String?
  technologies String?
  methods      String?
  order        Int     @default(0)

  @@map("experiences")
}

model Skill {
  id       String  @id @default(cuid())
  cvId     String
  cv       Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  name     String  @default("")
  category String  @default("technical")
  level    String?
  display  Boolean @default(true)
  order    Int     @default(0)

  @@map("skills")
}

model Education {
  id           String  @id @default(cuid())
  cvId         String
  cv           Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  degree       String  @default("")
  fieldOfStudy String?
  school       String  @default("")
  location     String?
  startYear    String?
  endYear      String?
  level        String?
  honors       String?
  order        Int     @default(0)

  @@map("educations")
}

model Language {
  id         String  @id @default(cuid())
  cvId       String
  cv         Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  language   String  @default("")
  cefrLevel  String?
  levelLabel String?
  display    Boolean @default(true)
  order      Int     @default(0)

  @@map("languages")
}

model Certification {
  id             String  @id @default(cuid())
  cvId           String
  cv             Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  name           String  @default("")
  issuer         String?
  issueDate      String?
  expirationDate String?
  credentialUrl  String?
  display        Boolean @default(true)
  order          Int     @default(0)

  @@map("certifications")
}
