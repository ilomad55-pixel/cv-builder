generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  logoUrl        String?
  primaryColor   String   @default("#3b5bdb")
  secondaryColor String   @default("#ffffff")
  fontFamily     String   @default("Arial")
  cvs            Cv[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("companies")
}

model Cv {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  originalFileUrl  String
  originalFileName String
  status           CvStatus    @default(PENDING)
  rawText          String?
  templateId       Int?
  generatedFileUrl String?
  contact          Contact?
  experiences      Experience[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("cvs")
}

enum CvStatus {
  PENDING
  TEXT_EXTRACTED
  PARSED
  GENERATED
}

model Contact {
  id          String  @id @default(cuid())
  cvId        String  @unique
  cv          Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  firstName   String  @default("")
  lastName    String  @default("")
  address     String?
  email       String?
  phone       String?
  profileText String?

  @@map("contacts")
}

model Experience {
  id           String  @id @default(cuid())
  cvId         String
  cv           Cv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  title        String  @default("")
  startDate    String  @default("")
  endDate      String?
  company      String  @default("")
  context      String?
  achievements String?
  technologies String?
  order        Int     @default(0)

  @@map("experiences")
}
